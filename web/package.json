{
  "name": "denoise-voice-clarity",
  "version": "0.2.0",
  "description": "Real-time in-browser noise suppression + voice clarity for WebRTC (DeepFilterNet 3, WASM). Open-source, license-free Krisp replacement. Works with plain getUserMedia or LiveKit. Lazy-loaded.",
  "license": "MIT",
  "author": {
    "name": "rajan471",
    "url": "https://www.npmjs.com/~rajan471"
  },
  "homepage": "https://www.npmjs.com/package/denoise-voice-clarity",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "noise-suppression",
    "noise-cancellation",
    "denoise",
    "voice",
    "voice-clarity",
    "webrtc",
    "getusermedia",
    "krisp",
    "krisp-alternative",
    "rnnoise",
    "deepfilternet",
    "audioworklet",
    "wasm",
    "livekit"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:wasm": "FEATURES=${FEATURES:-wasm} ../scripts/build-wasm.sh",
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "build:js": "node scripts/build.mjs",
    "build:types": "tsc -p tsconfig.json",
    "build": "npm run clean && npm run copy:wasm && npm run build:js && npm run build:types",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "livekit-client": "^2.17.0"
  },
  "peerDependenciesMeta": {
    "livekit-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
